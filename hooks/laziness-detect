#!/bin/bash
# laziness-detect - PostToolUse hook for Bash operations
# Detects laziness patterns LP001-LP006

set -e

# Arguments: $1 = tool name (Bash), $2+ = tool output
TOOL_NAME="$1"
TOOL_OUTPUT="$2"

# Global data directory (session-level)
DATA_DIR="$HOME/.claude/harness"
LAZINESS_LOG="$DATA_DIR/laziness-log.json"

# Find project root and version directory
find_version_dir() {
    local current_dir="$(pwd)"
    while [[ "$current_dir" != "/" ]]; do
        if [[ -d "$current_dir/output" ]]; then
            # Find version subdirectory
            for dir in "$current_dir/output"/v[0-9]*.[0-9]*; do
                if [[ -d "$dir" ]]; then
                    echo "$dir"
                    return 0
                fi
            done
        fi
        current_dir="$(dirname "$current_dir")"
    done
    return 1
}

PROJECT_VERSION_DIR=$(find_version_dir 2>/dev/null || true)

# Ensure data directories exist
mkdir -p "$DATA_DIR"
if [[ -n "$PROJECT_VERSION_DIR" ]]; then
    mkdir -p "$PROJECT_VERSION_DIR"
fi

# Initialize logs if not exist
for log_dir in "$DATA_DIR" "$PROJECT_VERSION_DIR"; do
    if [[ -n "$log_dir" && ! -f "$log_dir/laziness-log.json" ]]; then
        echo '[]' > "$log_dir/laziness-log.json"
    fi
done

# LP001: Completion claims without verification
# Pattern: "done", "completed", "finished" without test/verify commands

check_lp001() {
    local output="$1"

    # Completion keywords
    local completion_words=("done" "completed" "finished" "搞定" "完成" "搞完了")

    # Verification keywords
    local verify_words=("test" "verify" "check" "run" "测试" "验证" "检查")

    local has_completion=false
    local has_verification=false

    for word in "${completion_words[@]}"; do
        if [[ "$output" =~ $word ]]; then
            has_completion=true
            break
        fi
    done

    for word in "${verify_words[@]}"; do
        if [[ "$output" =~ $word ]]; then
            has_verification=true
            break
        fi
    done

    if [[ "$has_completion" == true && "$has_verification" == false ]]; then
        log_laziness "LP001" "completion_without_verification" "critical"
        return 1
    fi

    return 0
}

# LP002: Fix without root cause
# Pattern: "fix", "修复" without "why", "cause", "原因", "root"

check_lp002() {
    local output="$1"

    local fix_words=("fix" "fixed" "repair" "修复" "改了" "解决了")
    local cause_words=("why" "cause" "root" "reason" "原因" "根因" "为什么")

    local has_fix=false
    local has_cause=false

    for word in "${fix_words[@]}"; do
        if [[ "$output" =~ $word ]]; then
            has_fix=true
            break
        fi
    done

    for word in "${cause_words[@]}"; do
        if [[ "$output" =~ $word ]]; then
            has_cause=true
            break
        fi
    done

    if [[ "$has_fix" == true && "$has_cause" == false ]]; then
        log_laziness "LP002" "fix_without_root_cause" "critical"
        return 1
    fi

    return 0
}

# LP004: Test skip attempts
# Pattern: "skip test", "跳过测试", "不需要测试"

check_lp004() {
    local output="$1"

    local skip_patterns=("skip test" "skip test" "no test" "跳过测试" "不需要测试" "不用测试" "简单不用测")

    for pattern in "${skip_patterns[@]}"; do
        if [[ "$output" =~ $pattern ]]; then
            log_laziness "LP004" "test_skip_attempt" "critical"
            return 1
        fi
    done

    return 0
}

# Log laziness pattern to all log locations
log_laziness() {
    local pattern_id="$1"
    local pattern_type="$2"
    local severity="$3"
    local context="${4:-}"

    TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    local entry="{\"timestamp\": \"$TIMESTAMP\", \"pattern\": \"$pattern_id\", \"type\": \"$pattern_type\", \"severity\": \"$severity\", \"context\": \"$context\"}"

    # Log to global directory
    if [[ -f "$LAZINESS_LOG" ]]; then
        echo "$(cat "$LAZINESS_LOG")" | jq ". += [$entry]" > "$LAZINESS_LOG"
    fi

    # Log to project version directory if found
    if [[ -n "$PROJECT_VERSION_DIR" && -f "$PROJECT_VERSION_DIR/laziness-log.json" ]]; then
        echo "$(cat "$PROJECT_VERSION_DIR/laziness-log.json")" | jq ". += [$entry]" > "$PROJECT_VERSION_DIR/laziness-log.json"
    fi
}

# Log successful check (no laziness detected)
log_clean_check() {
    local checks_performed="$1"

    TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    local entry="{\"timestamp\": \"$TIMESTAMP\", \"check\": \"clean\", \"patterns_checked\": \"$checks_performed\", \"result\": \"no_laziness\"}"

    # Only log to project version directory if found (avoid noise in global log)
    if [[ -n "$PROJECT_VERSION_DIR" && -f "$PROJECT_VERSION_DIR/laziness-log.json" ]]; then
        echo "$(cat "$PROJECT_VERSION_DIR/laziness-log.json")" | jq ". += [$entry]" > "$PROJECT_VERSION_DIR/laziness-log.json"
    fi
}

# Run detection (non-blocking - just log and potentially warn)
check_lp001 "$TOOL_OUTPUT" || true
check_lp002 "$TOOL_OUTPUT" || true
check_lp004 "$TOOL_OUTPUT" || true

exit 0