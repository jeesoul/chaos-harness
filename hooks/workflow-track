#!/bin/bash
# workflow-track - PreToolUse hook for Glob|Grep|Read operations
# Tracks project iteration progress and detects timeouts

set -e

# Global data directory (session-level)
DATA_DIR="$HOME/.claude/harness"
WORKFLOW_LOG="$DATA_DIR/workflow-log.json"

# Find project root and version directory
find_version_dir() {
    local current_dir="$(pwd)"
    while [[ "$current_dir" != "/" ]]; do
        if [[ -d "$current_dir/output" ]]; then
            # Find version subdirectory
            for dir in "$current_dir/output"/v[0-9]*.[0-9]*; do
                if [[ -d "$dir" ]]; then
                    echo "$dir"
                    return 0
                fi
            done
        fi
        current_dir="$(dirname "$current_dir")"
    done
    return 1
}

PROJECT_VERSION_DIR=$(find_version_dir 2>/dev/null || true)

# Workflow state is in project version directory
WORKFLOW_STATE=""
if [[ -n "$PROJECT_VERSION_DIR" && -f "$PROJECT_VERSION_DIR/workflow-state.yaml" ]]; then
    WORKFLOW_STATE="$PROJECT_VERSION_DIR/workflow-state.yaml"
fi

# Ensure data directories exist
mkdir -p "$DATA_DIR"
if [[ -n "$PROJECT_VERSION_DIR" ]]; then
    mkdir -p "$PROJECT_VERSION_DIR"
fi

# Initialize logs if not exist
for log_dir in "$DATA_DIR" "$PROJECT_VERSION_DIR"; do
    if [[ -n "$log_dir" && ! -f "$log_dir/workflow-log.json" ]]; then
        echo '[]' > "$log_dir/workflow-log.json"
    fi
done

# Track tool usage for iteration metrics
track_tool_usage() {
    TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    TOOL_TYPE="$1"

    local entry="{\"event\": \"tool_use\", \"tool\": \"$TOOL_TYPE\", \"timestamp\": \"$TIMESTAMP\"}"

    # Log to global directory
    if [[ -f "$WORKFLOW_LOG" ]]; then
        echo "$(cat "$WORKFLOW_LOG")" | jq ". += [$entry]" > "$WORKFLOW_LOG"
    fi

    # Log to project version directory if found
    if [[ -n "$PROJECT_VERSION_DIR" && -f "$PROJECT_VERSION_DIR/workflow-log.json" ]]; then
        echo "$(cat "$PROJECT_VERSION_DIR/workflow-log.json")" | jq ". += [$entry]" > "$PROJECT_VERSION_DIR/workflow-log.json"
    fi
}

# Log stage event
log_stage_event() {
    local stage="$1"
    local event="$2"  # start, progress, complete, blocked
    local details="${3:-}"

    TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    local entry="{\"event\": \"stage_$event\", \"stage\": \"$stage\", \"timestamp\": \"$TIMESTAMP\""
    if [[ -n "$details" ]]; then
        entry="$entry, \"details\": \"$details\""
    fi
    entry="$entry}"

    # Log to project version directory if found
    if [[ -n "$PROJECT_VERSION_DIR" && -f "$PROJECT_VERSION_DIR/workflow-log.json" ]]; then
        echo "$(cat "$PROJECT_VERSION_DIR/workflow-log.json")" | jq ". += [$entry]" > "$PROJECT_VERSION_DIR/workflow-log.json"
    fi
}

# Check for stage timeout (LP003 detection)
check_timeout() {
    if [[ -z "$WORKFLOW_STATE" || ! -f "$WORKFLOW_STATE" ]]; then
        return 0
    fi

    # Parse current stage start time from YAML
    # Simplified - just check if workflow has been active for too long
    local workflow_start=$(grep "workflow_start:" "$WORKFLOW_STATE" | cut -d' ' -f2)

    if [[ -z "$workflow_start" ]]; then
        return 0
    fi

    # Calculate elapsed time (simplified - assumes ISO timestamp)
    local now=$(date +%s)
    local start=$(date -d "$workflow_start" +%s 2>/dev/null || echo "$now")

    local elapsed=$((now - start))

    # Timeout thresholds by project scale
    local scale=$(grep "project_scale:" "$WORKFLOW_STATE" | cut -d' ' -f2)

    local timeout_threshold=7200  # 2 hours default

    case "$scale" in
        "small")
            timeout_threshold=3600  # 1 hour
            ;;
        "medium")
            timeout_threshold=7200  # 2 hours
            ;;
        "large")
            timeout_threshold=14400  # 4 hours
            ;;
    esac

    # If elapsed > threshold * 1.5, warn LP003
    if [[ $elapsed -gt $((timeout_threshold * 3 / 2)) ]]; then
        log_timeout "$elapsed" "$timeout_threshold"
        return 1
    fi

    return 0
}

# Log timeout warning
log_timeout() {
    local elapsed="$1"
    local threshold="$2"

    TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    local entry="{\"event\": \"timeout_warning\", \"pattern\": \"LP003\", \"elapsed_seconds\": $elapsed, \"threshold_seconds\": $threshold, \"timestamp\": \"$TIMESTAMP\"}"

    # Log to project version directory if found
    if [[ -n "$PROJECT_VERSION_DIR" && -f "$PROJECT_VERSION_DIR/workflow-log.json" ]]; then
        echo "$(cat "$PROJECT_VERSION_DIR/workflow-log.json")" | jq ". += [$entry]" > "$PROJECT_VERSION_DIR/workflow-log.json"
    fi
}

# Run tracking and checks
# Check if workflow state exists
if [[ -n "$WORKFLOW_STATE" && -f "$WORKFLOW_STATE" ]]; then
    track_tool_usage "query"
    check_timeout || true
else
    # No active workflow, just track tool usage globally
    track_tool_usage "query"
fi

exit 0