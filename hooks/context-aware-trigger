#!/bin/sh
# context-aware-trigger - 智能场景感知
# PostToolUse hook for intelligent skill recommendation

# Disable MSYS2 path conversion to prevent Git Bash crash on Windows
export MSYS_NO_PATHCONV=1
export MSYS2_ARG_CONV_EXCL="*"

TOOL_NAME="$1"
TOOL_INPUT="$2"
TOOL_OUTPUT="$3"

DATA_DIR="$HOME/.claude/harness"
TRIGGER_LOG="$DATA_DIR/trigger-log.json"

mkdir -p "$DATA_DIR"
[ ! -f "$TRIGGER_LOG" ] && printf '[]\n' > "$TRIGGER_LOG"

# Parse file path from input
FILE_PATH=""
if [ -n "$TOOL_INPUT" ]; then
    FILE_PATH=$(printf '%s\n' "$TOOL_INPUT" | grep -o '"file_path"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | sed 's/.*"file_path"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/')
fi

# Output recommendation
recommend() {
    printf '\n<HARNESS_RECOMMEND>\n'
    printf '📌 **自动推荐:** %s\n' "$1"
    printf '</HARNESS_RECOMMEND>\n'
}

# Check file type
if [ -n "$FILE_PATH" ]; then
    # Vue detection
    case "$FILE_PATH" in
        *.vue)
            recommend "检测到 Vue 组件，已加载 Vue 模板铁律"
            ;;
        *.jsx|*.tsx)
            recommend "检测到 React 组件，已加载 React 模板铁律"
            ;;
        *PRD*|*需求*|*requirement*)
            recommend "检测到 PRD 文档，建议使用 product-lifecycle"
            ;;
        *.sql|*migration*|*schema*)
            printf '\n<HARNESS_IRON_LAW>⚡ IL-TECH003: 数据库变更需要迁移脚本</HARNESS_IRON_LAW>\n'
            ;;
        *.env|*secret*|*credential*)
            printf '\n<HARNESS_IRON_LAW>⚡ IL005: 敏感配置修改需要批准</HARNESS_IRON_LAW>\n'
            ;;
    esac
fi

exit 0