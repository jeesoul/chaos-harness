#!/bin/sh
# learning-update - PostToolUse hook for learning collection
# Records operations for later analysis by learning-analyzer

# Disable MSYS2 path conversion to prevent Git Bash crash on Windows
export MSYS_NO_PATHCONV=1
export MSYS2_ARG_CONV_EXCL="*"

DATA_DIR="$HOME/.claude/harness"
LEARNING_LOG="$DATA_DIR/learning-log.json"

mkdir -p "$DATA_DIR"
[ ! -f "$LEARNING_LOG" ] && printf '[]\n' > "$LEARNING_LOG"

TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

# Record operation for learning analysis
if command -v jq >/dev/null 2>&1; then
    printf '%s\n' "$(cat "$LEARNING_LOG")" | jq --arg ts "$TIMESTAMP" --arg event "operation" '. += [{"event": $event, "timestamp": $ts, "recorded": true}]' > "$LEARNING_LOG"
fi

exit 0