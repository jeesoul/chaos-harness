#!/bin/sh
# stop - Stop hook script
# Saves project state for next session recovery

DATA_DIR="$HOME/.claude/harness"
mkdir -p "$DATA_DIR"

# Detect project root
PROJECT_ROOT="$PWD"
_dir="$PWD"
while [ "$_dir" != "/" ]; do
    if [ -f "$_dir/.git" ] || [ -f "$_dir/pom.xml" ] || [ -f "$_dir/package.json" ]; then
        PROJECT_ROOT="$_dir"
        break
    fi
    _dir="$(dirname "$_dir")"
done

# Save state if exists
STATE_FILE="$PROJECT_ROOT/.chaos-harness/state.json"
if [ -f "$STATE_FILE" ] && command -v jq >/dev/null 2>&1; then
    TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    # Update last_session
    _tmp="/tmp/state_$$.json"
    jq --arg ts "$TIMESTAMP" '
        .last_session = $ts |
        .statistics.total_sessions += 1
    ' "$STATE_FILE" > "$_tmp" 2>/dev/null && \
        cat "$_tmp" > "$STATE_FILE" 2>/dev/null
    rm -f "$_tmp" 2>/dev/null

    # Log session end
    PLUGIN_LOG="$DATA_DIR/plugin-log.json"
    [ ! -f "$PLUGIN_LOG" ] && printf '[]\n' > "$PLUGIN_LOG"
    SESSION_ID=$(date +%s)
    printf '%s\n' "$(cat "$PLUGIN_LOG")" | jq --arg ts "$TIMESTAMP" --arg sid "$SESSION_ID" --arg root "$PROJECT_ROOT" '. += [{"event": "session_end", "timestamp": $ts, "session_id": $sid, "project_root": $root}]' > "$PLUGIN_LOG"
fi

exit 0