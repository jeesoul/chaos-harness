#!/bin/sh
# iron-law-check - PreToolUse hook for Write|Edit operations
# Validates operations against iron laws IL001-IL005

# Disable MSYS2 path conversion to prevent Git Bash crash on Windows
export MSYS_NO_PATHCONV=1
export MSYS2_ARG_CONV_EXCL="*"

TOOL_NAME="$1"
TOOL_INPUT="$2"

DATA_DIR="$HOME/.claude/harness"
IRON_LAW_LOG="$DATA_DIR/iron-law-log.json"

mkdir -p "$DATA_DIR"
[ ! -f "$IRON_LAW_LOG" ] && printf '[]\n' > "$IRON_LAW_LOG"

# Parse file path from input
FILE_PATH=""
if [ -n "$TOOL_INPUT" ]; then
    FILE_PATH=$(printf '%s\n' "$TOOL_INPUT" | grep -o '"file_path"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | sed 's/.*"\([^"]*\)"$/\1/')
fi

# If no file path, allow operation
[ -z "$FILE_PATH" ] && exit 0

# Check IL001: Version directory validation
# Check if path is in output/ without version
case "$FILE_PATH" in
    output/*)
        # Check if contains version pattern vX.Y
        if ! printf '%s\n' "$FILE_PATH" | grep -qE 'v[0-9]+\.[0-9]+'; then
            printf 'IL001 BLOCKED: NO DOCUMENTS WITHOUT VERSION LOCK\n'
            printf 'File path: %s\n' "$FILE_PATH"
            printf 'Required: output/vX.Y/... format\n'
            exit 1
        fi
        ;;
esac

# Check IL005: High-risk config files
case "$FILE_PATH" in
    *.env|*secret*|*credential*|*password*|*token*)
        printf 'IL005 WARNING: HIGH-RISK CONFIG MODIFICATION\n'
        printf 'File path: %s\n' "$FILE_PATH"
        printf 'Action: Confirm with user before modifying\n'
        ;;
esac

exit 0