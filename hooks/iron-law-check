#!/bin/bash
# iron-law-check - PreToolUse hook for Write|Edit operations
# Validates operations against iron laws IL001-IL005

set -e

# Arguments: $1 = tool name (Write or Edit), $2+ = tool input JSON
TOOL_NAME="$1"
TOOL_INPUT="$2"

# Global data directory (session-level)
DATA_DIR="$HOME/.claude/harness"
IRON_LAW_LOG="$DATA_DIR/iron-law-log.json"

# Find project root and version directory
find_version_dir() {
    local current_dir="$(pwd)"
    while [[ "$current_dir" != "/" ]]; do
        if [[ -d "$current_dir/output" ]]; then
            # Find version subdirectory
            for dir in "$current_dir/output"/v[0-9]*.[0-9]*; do
                if [[ -d "$dir" ]]; then
                    echo "$dir"
                    return 0
                fi
            done
        fi
        current_dir="$(dirname "$current_dir")"
    done
    return 1
}

PROJECT_VERSION_DIR=$(find_version_dir 2>/dev/null || true)

# Ensure data directories exist
mkdir -p "$DATA_DIR"
if [[ -n "$PROJECT_VERSION_DIR" ]]; then
    mkdir -p "$PROJECT_VERSION_DIR"
fi

# Initialize logs if not exist
for log_dir in "$DATA_DIR" "$PROJECT_VERSION_DIR"; do
    if [[ -n "$log_dir" && ! -f "$log_dir/iron-law-log.json" ]]; then
        echo '[]' > "$log_dir/iron-law-log.json"
    fi
done

# Parse file path from tool input (simplified - works with Claude Code's JSON format)
FILE_PATH=$(echo "$TOOL_INPUT" | jq -r '.file_path // .path // empty')

# If no file path, allow the operation
if [[ -z "$FILE_PATH" ]]; then
    exit 0
fi

# Check IL001: Version directory validation
# All documents must be under a version directory (vX.Y format)

check_il001() {
    local path="$1"

    # Check if path contains version directory pattern (v followed by digits and dot)
    if [[ "$path" =~ v[0-9]+\.[0-9]+ ]]; then
        log_check "IL001" "version_check" "pass" "path contains version: $path"
        return 0  # Valid - contains version
    fi

    # Check if path is in output/ directory (which should have version subdirs)
    if [[ "$path" =~ ^.*output/[^v] ]]; then
        # Path is in output but not in version subdir
        echo "IL001 BLOCKED: NO DOCUMENTS WITHOUT VERSION LOCK"
        echo "File path: $path"
        echo "Required: output/vX.Y/... format"
        echo "Action: Create version directory first or use existing version path"

        # Log the violation
        log_violation "IL001" "version_missing" "$path"

        exit 1  # Block the operation
    fi

    # Allow operations outside output/ directory (e.g., src/, tests/)
    log_check "IL001" "outside_output" "pass" "not a document output path"
    return 0
}

# Check IL005: High-risk config modifications
# Sensitive config files require approval

check_il005() {
    local path="$1"

    # List of high-risk config files
    local risky_configs=(
        ".env"
        "settings.json"
        "credentials"
        "secrets"
        "private"
        "auth"
        "password"
        "token"
    )

    for risky in "${risky_configs[@]}"; do
        if [[ "$path" =~ $risky ]]; then
            echo "IL005 WARNING: NO HIGH-RISK CONFIG MODS WITHOUT APPROVAL"
            echo "File path: $path"
            echo "Risk level: HIGH"
            echo "Action: Confirm with user before modifying sensitive config"

            # Log the warning (don't block, just warn)
            log_violation "IL005" "high_risk_config" "$path" "warning"

            # For hook, we just warn - actual blocking happens in Claude's response
            return 0
        fi
    done

    return 0
}

# Log iron law violation to all log locations
log_violation() {
    local law_id="$1"
    local trigger="$2"
    local path="$3"
    local action="${4:-blocked}"

    TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    local entry="{\"timestamp\": \"$TIMESTAMP\", \"iron_law\": \"$law_id\", \"trigger\": \"$trigger\", \"path\": \"$path\", \"action\": \"$action\"}"

    # Log to global directory
    if [[ -f "$IRON_LAW_LOG" ]]; then
        echo "$(cat "$IRON_LAW_LOG")" | jq ". += [$entry]" > "$IRON_LAW_LOG"
    fi

    # Log to project version directory if found
    if [[ -n "$PROJECT_VERSION_DIR" && -f "$PROJECT_VERSION_DIR/iron-law-log.json" ]]; then
        echo "$(cat "$PROJECT_VERSION_DIR/iron-law-log.json")" | jq ". += [$entry]" > "$PROJECT_VERSION_DIR/iron-law-log.json"
    fi
}

# Log successful check (for tracking)
log_check() {
    local law_id="$1"
    local operation="$2"
    local result="$3"
    local evidence="${4:-}"

    TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    local entry="{\"timestamp\": \"$TIMESTAMP\", \"iron_law\": \"$law_id\", \"operation\": \"$operation\", \"check\": \"pass\", \"result\": \"$result\""
    if [[ -n "$evidence" ]]; then
        entry="$entry, \"evidence\": \"$evidence\""
    fi
    entry="$entry}"

    # Log to project version directory if found
    if [[ -n "$PROJECT_VERSION_DIR" && -f "$PROJECT_VERSION_DIR/iron-law-log.json" ]]; then
        echo "$(cat "$PROJECT_VERSION_DIR/iron-law-log.json")" | jq ". += [$entry]" > "$PROJECT_VERSION_DIR/iron-law-log.json"
    fi
}

# Run checks
check_il001 "$FILE_PATH"
check_il005 "$FILE_PATH"

# All checks passed
exit 0