#!/bin/sh
# smart-trigger - 智能触发引擎
# 自动检测用户意图并推荐/激活对应 Skill

DATA_DIR="$HOME/.claude/harness"
TRIGGER_LOG="$DATA_DIR/trigger-log.json"
PROJECT_ROOT=""

mkdir -p "$DATA_DIR"
[ ! -f "$TRIGGER_LOG" ] && printf '[]\n' > "$TRIGGER_LOG"

# 检测项目根目录
detect_project_root() {
    _dir="$PWD"
    while [ "$_dir" != "/" ]; do
        [ -f "$_dir/.git" ] && { printf '%s\n' "$_dir"; return; }
        [ -f "$_dir/pom.xml" ] && { printf '%s\n' "$_dir"; return; }
        [ -f "$_dir/package.json" ] && { printf '%s\n' "$_dir"; return; }
        [ -f "$_dir/requirements.txt" ] && { printf '%s\n' "$_dir"; return; }
        _dir="$(dirname "$_dir")"
    done
    printf '%s\n' "$PWD"
}
PROJECT_ROOT=$(detect_project_root)

# === 项目状态检测 ===

check_project_state() {
    _state_file="$PROJECT_ROOT/.chaos-harness/state.json"

    if [ -f "$_state_file" ]; then
        printf '\n'
        printf '<HARNESS_STATE_DETECTED>\n'
        printf '📂 **检测到项目状态**\n'
        printf '- 路径: %s\n' "$PROJECT_ROOT"
        printf '\n'
        printf '💡 **建议:** 说 '\''继续'\'' 或使用 `/chaos-harness:project-state` 恢复\n'
        printf '</HARNESS_STATE_DETECTED>\n'
        return 0
    fi

    check_new_project
}

check_new_project() {
    _has_code=0
    _has_version=0

    [ -f "$PROJECT_ROOT/pom.xml" ] && _has_code=1
    [ -f "$PROJECT_ROOT/package.json" ] && _has_code=1
    [ -f "$PROJECT_ROOT/requirements.txt" ] && _has_code=1
    [ -d "$PROJECT_ROOT/output" ] && _has_version=1

    if [ $_has_code -eq 1 ] && [ $_has_version -eq 0 ]; then
        printf '\n'
        printf '<HARNESS_NEW_PROJECT>\n'
        printf '🆕 **检测到新项目**\n'
        printf '\n'
        printf '**建议初始化步骤:**\n'
        printf '1. `/chaos-harness:project-scanner` - 扫描项目\n'
        printf '2. `/chaos-harness:version-locker` - 创建版本\n'
        printf '3. `/chaos-harness:harness-generator` - 生成约束\n'
        printf '\n'
        printf '或直接说 '\''初始化项目'\'' 一键完成\n'
        printf '</HARNESS_NEW_PROJECT>\n'
    fi
}

# === 技术栈检测 ===

detect_tech_stack() {
    _pkg="$PROJECT_ROOT/package.json"
    _pom="$PROJECT_ROOT/pom.xml"
    _req="$PROJECT_ROOT/requirements.txt"

    # 前端检测
    if [ -f "$_pkg" ]; then
        if grep -q '"vue"' "$_pkg" 2>/dev/null; then
            printf '<HARNESS_TECH_STACK>🎨 **Vue** 项目检测 → 自动加载 vue 模板铁律</HARNESS_TECH_STACK>\n'
        elif grep -q '"react"' "$_pkg" 2>/dev/null; then
            printf '<HARNESS_TECH_STACK>⚛️ **React** 项目检测 → 自动加载 react 模板铁律</HARNESS_TECH_STACK>\n'
        elif grep -q '"next"' "$_pkg" 2>/dev/null; then
            printf '<HARNESS_TECH_STACK>▲ **Next.js** 项目检测 → 自动加载 react 模板铁律</HARNESS_TECH_STACK>\n'
        fi
    fi

    # 后端检测
    if [ -f "$_pom" ]; then
        if grep -q "spring-boot" "$_pom" 2>/dev/null; then
            printf '<HARNESS_TECH_STACK>☕ **Spring Boot** 项目检测 → 自动加载 java-spring 模板</HARNESS_TECH_STACK>\n'
        fi
    fi

    if [ -f "$_req" ]; then
        if grep -q "django" "$_req" 2>/dev/null; then
            printf '<HARNESS_TECH_STACK>🐍 **Django** 项目检测 → 自动加载 python-django 模板</HARNESS_TECH_STACK>\n'
        fi
    fi
}

# === 主执行 ===

# 项目状态检测
check_project_state

# 技术栈检测
detect_tech_stack

exit 0