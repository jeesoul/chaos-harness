#!/bin/sh
# session-start - SessionStart hook script
# Injects iron laws and restores project state at session start

# Data directories
GLOBAL_DATA_DIR="$HOME/.claude/harness"
PROJECT_STATE_DIR=""
IRON_LAW_LOG="$GLOBAL_DATA_DIR/iron-law-log.json"
PLUGIN_LOG="$GLOBAL_DATA_DIR/plugin-log.json"

# Ensure global data directory exists
mkdir -p "$GLOBAL_DATA_DIR"

# Initialize log files if they don't exist
if [ ! -f "$IRON_LAW_LOG" ]; then
    printf '[]\n' > "$IRON_LAW_LOG"
fi

if [ ! -f "$PLUGIN_LOG" ]; then
    printf '[]\n' > "$PLUGIN_LOG"
fi

# Detect project root (look for common project markers)
detect_project_root() {
    dir="$PWD"
    while [ "$dir" != "/" ]; do
        if [ -f "$dir/.chaos-harness/state.json" ] || \
           [ -f "$dir/pom.xml" ] || \
           [ -f "$dir/package.json" ] || \
           [ -f "$dir/requirements.txt" ] || \
           [ -d "$dir/.git" ]; then
            printf '%s\n' "$dir"
            return 0
        fi
        dir="$(dirname "$dir")"
    done
    printf '%s\n' "$PWD"
}

PROJECT_ROOT=$(detect_project_root)
PROJECT_STATE_DIR="$PROJECT_ROOT/.chaos-harness"
PROJECT_STATE_FILE="$PROJECT_STATE_DIR/state.json"

# Check if project state exists
check_project_state() {
    if [ -f "$PROJECT_STATE_FILE" ]; then
        return 0  # State exists
    fi
    return 1  # No state
}

# Output iron laws context
cat << 'IRON_LAWS_CONTEXT'
<CHAOS_HARNESS_CONTEXT>
**Iron Laws Active (不可协商):**

| ID | 铁律 | 说明 |
|----|------|------|
| IL001 | NO DOCUMENTS WITHOUT VERSION LOCK | 所有输出必须在版本目录下 |
| IL002 | NO HARNESS WITHOUT SCAN RESULTS | Harness需要项目扫描数据 |
| IL003 | NO COMPLETION CLAIMS WITHOUT VERIFICATION | 完成声明需要实际验证 |
| IL004 | NO VERSION CHANGES WITHOUT USER CONSENT | 版本变更需要用户确认 |
| IL005 | NO HIGH-RISK CONFIG MODS WITHOUT APPROVAL | 敏感配置修改需要批准 |

**Laziness Patterns Detected (偷懒模式):**

| ID | 模式 | 严重程度 |
|----|------|---------|
| LP001 | 声称完成但无验证证据 | critical |
| LP002 | 跳过根因分析直接修复 | critical |
| LP003 | 长时间无产出 (timeout) | warning |
| LP004 | 试图跳过测试 | critical |
| LP005 | 擅自更改版本号 | critical |
| LP006 | 自动处理高风险配置 | critical |

**Bypass Detection Keywords:**
- "简单修复" / "simple fix"
- "跳过测试" / "skip test"
- "就这一次" / "just this once"
- "快速处理" / "quick fix"

如果检测到上述模式，必须反驳并提供正确路径。
</CHAOS_HARNESS_CONTEXT>
IRON_LAWS_CONTEXT

# Project state recovery
if check_project_state; then
    printf '\n'
    printf '<CHAOS_HARNESS_STATE_RECOVERY>\n'
    printf '项目状态文件已检测到: %s\n' "$PROJECT_STATE_FILE"
    printf '\n'
    printf '**建议操作:**\n'
    printf '使用 /chaos-harness:project-state 或说 '\''继续上次进度'\'' 恢复会话。\n'
    printf '\n'

    # Extract key info for quick display (if jq available)
    if command -v jq >/dev/null 2>&1; then
        CURRENT_VERSION=$(cat "$PROJECT_STATE_FILE" | jq -r '.current_version // "未设置"')
        CURRENT_STAGE=$(cat "$PROJECT_STATE_FILE" | jq -r '.workflow.current_stage // "未开始"')
        LAST_SESSION=$(cat "$PROJECT_STATE_FILE" | jq -r '.last_session // "N/A"')
        PROJECT_NAME=$(cat "$PROJECT_STATE_FILE" | jq -r '.project_name // "Unknown"')

        printf '**快速状态:**\n'
        printf '- 项目: %s\n' "$PROJECT_NAME"
        printf '- 版本: %s\n' "$CURRENT_VERSION"
        printf '- 阶段: %s\n' "$CURRENT_STAGE"
        printf '- 上次会话: %s\n' "$LAST_SESSION"
    fi

    printf '</CHAOS_HARNESS_STATE_RECOVERY>\n'
else
    printf '\n'
    printf '<CHAOS_HARNESS_NEW_PROJECT>\n'
    printf '未检测到项目状态文件。\n'
    printf '\n'
    printf '这是一个新项目或首次使用 Chaos Harness。\n'
    printf '\n'
    printf '**建议操作:**\n'
    printf '1. 使用 /chaos-harness:project-scanner 扫描项目\n'
    printf '2. 使用 /chaos-harness:version-locker 创建版本\n'
    printf '3. 使用 /chaos-harness:harness-generator 生成约束\n'
    printf '\n'
    printf '或说 '\''开始使用 chaos-harness'\'' 进行初始化。\n'
    printf '</CHAOS_HARNESS_NEW_PROJECT>\n'
fi

# Log session start
TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
SESSION_ID=$(date +%s)

if command -v jq >/dev/null 2>&1; then
    printf '%s\n' "$(cat "$PLUGIN_LOG")" | jq --arg ts "$TIMESTAMP" --arg sid "$SESSION_ID" --arg root "$PROJECT_ROOT" '. += [{"event": "session_start", "timestamp": $ts, "session_id": $sid, "project_root": $root}]' > "$PLUGIN_LOG"
fi

exit 0