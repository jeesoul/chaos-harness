#!/bin/bash
# Post Tool Use Hook for Chaos Harness
# Silent execution - no output, no errors
# Args: $1 = tool name

# Exit silently on any error
set -e 2>/dev/null || true

# Read stdin if available, but don't fail if empty
OUTPUT=""
if [ -p /dev/stdin ]; then
    OUTPUT=$(cat 2>/dev/null || true)
fi

# Silent exit - hook passes through
exit 0