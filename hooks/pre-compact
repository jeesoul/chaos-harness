#!/bin/sh
# pre-compact - 对话压缩前保存关键上下文
# 保存当前进度、铁律触发、关键决策，防止压缩后丢失

# Disable MSYS2 path conversion to prevent Git Bash crash on Windows
export MSYS_NO_PATHCONV=1
export MSYS2_ARG_CONV_EXCL="*"

DATA_DIR="$HOME/.claude/harness"
mkdir -p "$DATA_DIR"

TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
COMPACT_FILE="$DATA_DIR/last-compact.json"

# 检测项目根目录
PROJECT_ROOT="$PWD"
_dir="$PWD"
_max_depth=20
_count=0
while [ "$_count" -lt "$_max_depth" ]; do
    if [ -d "$_dir/.git" ] || [ -f "$_dir/pom.xml" ] || [ -f "$_dir/package.json" ]; then
        PROJECT_ROOT="$_dir"
        break
    fi
    parent="$(dirname "$_dir")"
    if [ "$parent" = "$_dir" ]; then break; fi
    _dir="$parent"
    _count=$((_count + 1))
done

# 提取关键状态
STATE_FILE="$PROJECT_ROOT/.chaos-harness/state.json"
CURRENT_VERSION=""
CURRENT_STAGE=""
IRON_LAW_COUNT=0
LAZINESS_COUNT=0

if [ -f "$STATE_FILE" ] && command -v jq >/dev/null 2>&1; then
    CURRENT_VERSION=$(jq -r '.current_version // "未设置"' "$STATE_FILE" 2>/dev/null)
    CURRENT_STAGE=$(jq -r '.workflow.current_stage // "未开始"' "$STATE_FILE" 2>/dev/null)
fi

if [ -f "$DATA_DIR/iron-law-log.json" ] && command -v jq >/dev/null 2>&1; then
    IRON_LAW_COUNT=$(jq 'length' "$DATA_DIR/iron-law-log.json" 2>/dev/null || echo 0)
fi

if [ -f "$DATA_DIR/laziness-log.json" ] && command -v jq >/dev/null 2>&1; then
    LAZINESS_COUNT=$(jq 'length' "$DATA_DIR/laziness-log.json" 2>/dev/null || echo 0)
fi

# 保存压缩前快照
cat > "$COMPACT_FILE" << EOF
{
  "compact_at": "$TIMESTAMP",
  "project_root": "$PROJECT_ROOT",
  "current_version": "$CURRENT_VERSION",
  "current_stage": "$CURRENT_STAGE",
  "iron_law_triggers": $IRON_LAW_COUNT,
  "laziness_detections": $LAZINESS_COUNT
}
EOF

# 输出上下文摘要（帮助压缩后恢复）
printf '\n<CHAOS_HARNESS_COMPACT>\n'
printf '📌 压缩前状态:\n'
printf '   版本: %s | 阶段: %s\n' "$CURRENT_VERSION" "$CURRENT_STAGE"
printf '   铁律触发: %d 次 | 偷懒检测: %d 次\n' "$IRON_LAW_COUNT" "$LAZINESS_COUNT"
printf '</CHAOS_HARNESS_COMPACT>\n'

exit 0
