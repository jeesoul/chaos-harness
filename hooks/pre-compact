#!/bin/sh
# pre-compact - PreCompact hook script
# Preserves essential context before conversation compaction

DATA_DIR="$HOME/.claude/harness"
mkdir -p "$DATA_DIR"

# Simple archive - just create a marker
TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
ARCHIVE_FILE="$DATA_DIR/last-compact.txt"

printf '%s\n' "$TIMESTAMP" > "$ARCHIVE_FILE"

exit 0