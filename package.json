{
  "name": "chaos-harness",
  "version": "1.0.0",
  "description": "Claude Code 智能项目入侵系统 - 扫描、版本约束、Harness生成、偷懒检测、工作流管理",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "chaos-harness-mcp": "./bin/mcp-server.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "templates", "bin"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "claude",
    "claude-code",
    "mcp",
    "harness",
    "workflow",
    "scanner",
    "version-manager",
    "iron-laws",
    "project-invasion",
    "laziness-detection",
    "adaptive-flow"
  ],
  "author": "Chaos Harness Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chaos-harness/chaos-harness.git"
  },
  "bugs": {
    "url": "https://github.com/chaos-harness/chaos-harness/issues"
  },
  "homepage": "https://github.com/chaos-harness/chaos-harness#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/xml2js": "^0.4.14",
    "execa": "^9.6.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "xml2js": "^0.6.2",
    "yaml": "^2.8.3"
  }
}